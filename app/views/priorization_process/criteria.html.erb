<h2>PriorizationProcessController#criteria</h2>

<form>
    <div class="pr-board box">
        <table class="table w-50 mt-5">
             <thead class="thead-dark">
                <tr>
                    <th> Ponderacion de criterios </th>
                </tr>
             </thead>

             <tbody>
                <tr>
                  <td>
                    <label for="criteria <%= criteria['id'] %>"> <%= criteria['id'] %>. </label>
                    <%= criteria['name']%>
                  </td>
                </tr>
             </tbody>
        </table>
    </div>

    <div class='buttons'>
      <input type="submit" value='Seleccionar'>
    </div>
</form>